{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions for the Omi main + floating-bar windows.",
  "windows": ["main", "floating_bar"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-start-dragging",
    "global-shortcut:default",
    "notification:default",
    "autostart:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://api.omi.me/*" }, { "url": "http://localhost:*/*" }]
    }
  ]
}
