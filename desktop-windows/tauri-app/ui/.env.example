# Use the SAME Firebase project as production Omi so api.omi.me accepts the tokens.
# Copy to .env.local and fill in (values from the Omi Firebase console).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional: point Rust at a non-prod backend (defaults to https://api.omi.me)
# OMI_API_BASE_URL=https://api.omi.me
